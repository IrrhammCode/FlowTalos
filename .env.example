# ==============================================================================
# FLOWTALOS - ENVIRONMENT CONFIGURATION
# ==============================================================================
# This file serves as a template for your environment variables.
# Copy this file to `.env` or `.env.local` (for the web interface) 
# and fill in the corresponding values.
# 
# Command: `cp .env.example .env`
# ==============================================================================


# ------------------------------------------------------------------------------
# 1. WEB DASHBOARD (Next.js - frontend)
# ------------------------------------------------------------------------------

# WalletConnect Project ID [Required]
# Used by RainbowKit to authenticate EVM wallets.
# How to get: 
#   1. Go to https://cloud.walletconnect.com/
#   2. Sign in and create a new Project
#   3. Copy the 'Project ID'
NEXT_PUBLIC_WC_PROJECT_ID="your_walletconnect_project_id_here"


# ------------------------------------------------------------------------------
# 2. AI AGENT & SECURITY PROTOCOLS (Python / Node.js - backend)
# ------------------------------------------------------------------------------

# --- STORACHA NETWORK (Decentralized Audit Logging) ---
# Used to compute and pin cryptographic proofs of the AI's reasoning to IPFS.
# Note: If left blank, the application will fallback to computing local CIDv1 
# hashes (SHA-256) without pinning them to the remote Storacha network.
# 
# How to get:
#   1. Install the w3cli: `npm install -g @web3-storage/w3cli`
#   2. Authenticate: `w3 login your@email.com`
#   3. Create a space: `w3 space create "FlowTalos Audit Log"`
#   4. Register space: `w3 space register`
#   5. Find your Space DID: `w3 space ls` (looks like did:key:z6Mk...)
STORACHA_EMAIL_ADDRESS="your_registered_email@example.com"
STORACHA_SPACE_DID="did:key:your_storacha_space_did_here"


# --- LIT PROTOCOL (Cross-Chain Computation & Signing) ---
# The AI agent uses Lit Actions and a Programmable Key Pair (PKP) to securely
# construct and sign Flow EVM and Cadence transactions without exposing private keys.
# 
# Note: For local development, the agent will simulate the Lit signing process
# locally if no PKP is provided.
# 
# How to get:
#   1. Go to Lit Explorer (Chronicle Yellowstone): https://explorer.litprotocol.com/
#   2. Connect your wallet and mint a new PKP.
#   3. Copy the 'Public Key' generated for that PKP.
LIT_PKP_PUBLIC_KEY="0x_your_lit_pkp_public_key_here"


# ------------------------------------------------------------------------------
# 3. FLOW BLOCKCHAIN (Cadence Smart Contracts)
# ------------------------------------------------------------------------------

# --- FLOW CLI DEPLOYMENT ---
# The Flow CLI uses `flow.json` for network configuration.
# To deploy the contracts to Testnet, you must generate a Testnet account.
# 
# Instructions:
#   1. Run: `flow keys generate` to get a public/private keypair
#   2. Go to: https://faucet.flow.com/
#   3. Create a new Testnet account using your generated public key
#   4. Add the resulting address and private key to `flow.json` under `accounts`
#   5. Deploy: `flow project deploy --network=testnet`
