# =============================================================================
# FlowTalos — Root Demonstration Environment Variables
# =============================================================================
# This file is provided for the Hackathon Judges to easily configure all
# necessary keys from the project root instead of entering directories.
# Copy this file to `.env` and fill the variables.
# =============================================================================

# ── 1. Web Dashboard (Next.js) ───────────────────────────────────────────────
# Get your WalletConnect Project ID from: https://cloud.walletconnect.com
NEXT_PUBLIC_WC_PROJECT_ID=your_reown_walletconnect_project_id_here

# ── 2. Storacha IPFS Logger ──────────────────────────────────────────────────
# Your registered email for web3.storage pinning
STORACHA_EMAIL_ADDRESS=your_email@domain.com
# Space DID to authorize uploads
STORACHA_SPACE_DID=did:key:your_space_did_here

# ── 3. Flow Blockchain & AI Agent ────────────────────────────────────────────
# The Flow Testnet Account executing the scheduled strategies
FLOW_TESTNET_SIGNER=24c2e530f15129b7
# (Optional) Testnet RPC endpoint for custom EVM reads
FLOW_EVM_RPC_URL=https://testnet.evm.nodes.onflow.org

# ── 4. Lit Protocol Authentication ───────────────────────────────────────────
# Programmable Key Pair (PKP) Public Key minted on Yellowstone
LIT_PKP_PUBLIC_KEY=0x...
# Network ID (default is Yellowstone testnet for development)
LIT_NETWORK=yellowstone
