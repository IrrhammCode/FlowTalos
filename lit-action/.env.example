# =============================================================================
# FlowTalos — Lit Protocol Threshold Environment Variables
# =============================================================================
# Copy this file to `.env` before running simulateLitNode.js
# =============================================================================

# The Lit Network to connect to (yellowstone, habanero, custom)
LIT_NETWORK=yellowstone

# Your minted Programmable Key Pair (PKP) Public Key (Starts with 0x)
LIT_PKP_PUBLIC_KEY=your_pkp_pubkey_here

# Mode toggle: set to "local" to run simulations, or "prod" for live network bridging
FLOWTALOS_ACTION_MODE=local

# When simulating, pass the JSON payload string here
FLOWTALOS_SIGNAL='{"action":"BUY","token":"FLOW","amount":100}'
