# -----------------------------------------------------------------------------
# FlowTalos: Impulse AI Agent Environment Variables
# -----------------------------------------------------------------------------
# Copy this file to '.env' and fill in your specific credentials.
# Do NOT commit your actual '.env' file to version control.

# CoinGecko API Key (Optional for free tier, but recommended for production)
COINGECKO_API_KEY=your_coingecko_api_key_here

# CryptoPanic API Key (Optional, used for fetching social/news sentiment)
CRYPTOPANIC_API_KEY=your_cryptopanic_api_key_here

# RPC Provider for Flow EVM (If generating complex on-chain calldata requiring state reads)
FLOW_EVM_RPC_URL=https://testnet.evm.nodes.onflow.org

# OpenAI / Anthropic API Key (If upgrading the AI reasoning engine to an LLM)
# OPENAI_API_KEY=sk-your_openai_key_here
