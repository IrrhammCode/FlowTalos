# =============================================================================
# FlowTalos — Impulse AI Agent Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in your specific credentials.
# The AI agent is designed to run entirely offline with graceful fallbacks
# if these APIs are unreachable.
# =============================================================================

# Flow Testnet Signer Account Address

# X (Twitter) API Bearer Token (Optional: Used for social sentiment analysis)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here
FLOW_TESTNET_SIGNER=24c2e530f15129b7

# CoinGecko API Key (Optional: Public tier is used if blank, but rate-limited)
COINGECKO_API_KEY=your_coingecko_api_key_here

# CryptoCompare API Key (Optional: For higher volume sentiment scanning)
CRYPTOCOMPARE_API_KEY=your_cryptocompare_api_key_here

# RPC Provider for Flow EVM (Optional: Defaults to public Testnet node)
FLOW_EVM_RPC_URL=https://testnet.evm.nodes.onflow.org

# OpenAI / Anthropic API Key (If upgrading the reasoning matrix to an LLM)
OPENAI_API_KEY=sk-your_openai_key_here
