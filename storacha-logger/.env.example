# -----------------------------------------------------------------------------
# FlowTalos: Storacha IPFS Logger Environment Variables
# -----------------------------------------------------------------------------
# Copy this file to '.env' and fill in your specific credentials.
# Do NOT commit your actual '.env' file to version control.

# The email address registered with your Storacha (web3.storage) account
STORACHA_EMAIL_ADDRESS=your.email@example.com

# The DID of the Space you want to upload files into (optional if using default space)
# STORACHA_SPACE_DID=did:key:z6Mk...

# Private Key for programmatic access (If bypassing the email login flow)
# STORACHA_PRIVATE_KEY=your_private_key_export
